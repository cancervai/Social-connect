generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum Platform {
  META
  LINKEDIN
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum VerificationStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
}

model Workspace {
  id                 String             @id @default(uuid())
  name               String
  plan               String             @default("free")
  verificationStatus VerificationStatus @default(NOT_STARTED)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  users          User[]
  socialAccounts SocialAccount[]
  posts          Post[]
  leads          Lead[]
  campaigns      Campaign[]
  analytics      Analytics[]
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(MEMBER)
  avatarUrl    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SocialAccount {
  id           String   @id @default(uuid())
  platform     Platform
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  pageId       String?
  pageName     String?
  profileName  String?
  profileImage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, platform])
}

model Post {
  id          String     @id @default(uuid())
  content     String
  platforms   Platform[]
  status      PostStatus @default(DRAFT)
  scheduledAt DateTime?
  publishedAt DateTime?
  errorMsg    String?
  metaPostId  String?
  liPostId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Analytics {
  id         String   @id @default(uuid())
  platform   Platform
  metricType String
  value      Float
  date       DateTime

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, platform, date])
}

model Lead {
  id         String     @id @default(uuid())
  firstName  String
  lastName   String?
  email      String?
  phone      String?
  source     Platform
  externalId String?
  status     LeadStatus @default(NEW)
  notes      String?
  metadata   Json?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, externalId, source])
}

model Campaign {
  id          String         @id @default(uuid())
  externalId  String
  platform    Platform
  name        String
  status      CampaignStatus @default(DRAFT)
  budget      Float?
  spend       Float          @default(0)
  impressions Int            @default(0)
  clicks      Int            @default(0)
  cpc         Float?
  ctr         Float?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, externalId, platform])
}
